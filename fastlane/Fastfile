default_platform(:ios)

# Fully headless build → sign → TestFlight. Runs only on the macOS CI runner.
# All credentials come from env (GitHub Actions secrets/vars); nothing
# interactive, no Apple ID password, no 2FA.

APP_ID = ENV["APP_IDENTIFIER"] || "com.madhakish.Cadence"
# The Live Activity ships in an embedded widget extension with its own App ID,
# which needs its own distribution profile or the archive won't sign.
WIDGET_ID = "#{APP_ID}.Widgets"

platform :ios do
  desc "Build a Release archive and upload it to TestFlight"
  lane :beta do
    # Create + unlock a temporary CI keychain so `match` imports the distribution
    # cert somewhere `codesign` can use non-interactively. Without this, match
    # lands the cert in the locked login keychain and codesign blocks forever on a
    # keychain-access GUI prompt — the headless macOS-runner build hangs at the
    # "Signing …" step (observed: a 59-min stall on an orphaned codesign process).
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"], # base64 of the .p8 (robust for multiline secrets)
      is_key_content_base64: true
    )

    # Generate Cadence.xcodeproj from the XcodeGen spec (gitignored in repo).
    sh("cd .. && xcodegen generate")

    # NOTE: the App ID (com.madhakish.Cadence, with HealthKit enabled) and the
    # App Store Connect app record are created once by hand — see docs/TESTFLIGHT.md.
    # That's more reliable than headless `produce`.

    # Fetch (or create on first run) the distribution cert + provisioning
    # profiles for BOTH the app and the widget extension. If the widget App ID
    # (com.madhakish.Cadence.Widgets) doesn't yet exist, `readonly: false` +
    # the API key registers it — or create it by hand like the main App ID
    # (see docs/TESTFLIGHT.md).
    match(type: "appstore", app_identifier: [APP_ID, WIDGET_ID], api_key: api_key, readonly: false)

    # Switch each target to manual signing with its match profile.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Cadence.xcodeproj",
      targets: ["Cadence"],
      team_id: ENV["DEVELOPER_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: ENV["sigh_#{APP_ID}_appstore_profile-name"]
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Cadence.xcodeproj",
      targets: ["CadenceWidgets"],
      team_id: ENV["DEVELOPER_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: ENV["sigh_#{WIDGET_ID}_appstore_profile-name"]
    )

    # Version + build number are driven entirely by build-setting overrides at
    # archive time, which the generated Info.plist references via
    # $(MARKETING_VERSION) / $(CURRENT_PROJECT_VERSION). This is deterministic
    # and avoids agvtool touching a literal Info.plist.
    #   - MARKETING_VERSION → the semantic-release version (APP_VERSION = the v*
    #     tag minus "v"), so TestFlight maps 1:1 to the released version.
    #   - CURRENT_PROJECT_VERSION → a monotonic build number from TestFlight.
    next_build = latest_testflight_build_number(
      api_key: api_key, app_identifier: APP_ID, initial_build_number: 0
    ) + 1
    app_version = ENV["APP_VERSION"].to_s.strip
    version_arg = app_version.empty? ? "" : " MARKETING_VERSION=#{app_version}"

    build_app(
      scheme: "Cadence",
      project: "Cadence.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          APP_ID => ENV["sigh_#{APP_ID}_appstore_profile-name"],
          WIDGET_ID => ENV["sigh_#{WIDGET_ID}_appstore_profile-name"]
        }
      },
      xcargs: "-allowProvisioningUpdates CURRENT_PROJECT_VERSION=#{next_build}#{version_arg}"
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_ID,
      skip_waiting_for_build_processing: true
    )
  end
end
