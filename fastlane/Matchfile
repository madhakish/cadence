# Signing certificates + provisioning profiles are generated once via the App
# Store Connect API and stored (encrypted) in a separate private git repo, so
# CI can fetch them on every run. No Mac, no Keychain, no manual cert wrangling.
git_url(ENV["MATCH_GIT_URL"])
storage_mode("git")
type("appstore")
app_identifier([
  ENV["APP_IDENTIFIER"] || "com.madhakish.Cadence",
  "#{ENV["APP_IDENTIFIER"] || "com.madhakish.Cadence"}.Widgets" # Live Activity widget extension
])
# Read-only by default: routine CI builds must never be able to rewrite the
# signing material in the certs repo (and the PAT behind
# MATCH_GIT_BASIC_AUTHORIZATION can be scoped read-only to match). For one-off
# provisioning of a new cert/profile, set MATCH_READONLY=false and use a
# read/write PAT, then revert both.
readonly(ENV["MATCH_READONLY"] != "false")
